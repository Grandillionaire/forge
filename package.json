{
  "name": "forge",
  "productName": "Forge",
  "version": "0.1.0",
  "description": "Forge — bulk media tooling. AI image upscaling, batch compression, AI video upscaling. Local-first, GPU-accelerated.",
  "main": "out/main/index.js",
  "author": {
    "name": "Forge Contributors"
  },
  "license": "MIT",
  "homepage": "https://github.com/Grandillionaire/forge",
  "repository": {
    "type": "git",
    "url": "https://github.com/Grandillionaire/forge.git"
  },
  "bugs": {
    "url": "https://github.com/Grandillionaire/forge/issues"
  },
  "keywords": [
    "image-upscaling",
    "video-upscaling",
    "real-esrgan",
    "image-compression",
    "batch-processing",
    "electron",
    "ai-upscaling",
    "ffmpeg"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac --arm64 --config electron-builder.yml",
    "build:mac:all": "electron-vite build && electron-builder --mac --arm64 --x64 --config electron-builder.yml",
    "build:win": "electron-vite build && electron-builder --win --x64 --arm64 --config electron-builder.yml",
    "build:linux": "electron-vite build && electron-builder --linux --x64 --arm64 --config electron-builder.yml",
    "release": "electron-vite build && electron-builder --mac --publish always --config electron-builder.yml",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "exiftool-vendored": "^35.19.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.11.7",
    "lucide-react": "^0.460.0",
    "p-queue": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^42.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
